# Postgres connection string (Railway provides this automatically when you add the Postgres plugin)
DATABASE_URL="postgresql://user:password@localhost:5432/citizen_test?schema=public"

# NextAuth
# Use the deployed URL in production (e.g. https://your-app.up.railway.app)
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"

# Google OAuth credentials (see README for setup steps)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Comma-separated list of Google account emails allowed to sign in
# e.g. "wife@example.com,me@example.com"
ALLOWED_EMAILS=""
