// Prisma schema for the Citizenship Test study app.
// Uses Postgres (Railway plugin in production).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- NextAuth required models ---

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts         Account[]
  sessions         Session[]
  chapterProgress  ChapterProgress[]
  attempts         Attempt[]
  testSessions     TestSession[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- App models ---

// Per-user, per-chapter progress (reading + best score).
model ChapterProgress {
  id               String   @id @default(cuid())
  userId           String
  chapterSlug      String
  readingCompleted Boolean  @default(false)
  bestScore        Int?     // out of 10
  lastAttemptAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterSlug])
}

// Individual question attempts (useful for weighting selection).
model Attempt {
  id            String   @id @default(cuid())
  userId        String
  questionId    String
  chapterSlug   String
  answeredIndex Int
  isCorrect    Boolean
  answeredAt   DateTime @default(now())
  testSessionId String?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  testSession TestSession? @relation(fields: [testSessionId], references: [id], onDelete: SetNull)
}

// A completed run of either a chapter test or a full practice test.
model TestSession {
  id          String   @id @default(cuid())
  userId      String
  mode        String   // "chapter" | "full_test"
  chapterSlug String?  // null for full_test
  total       Int
  score       Int
  passed      Boolean? // null for chapter mode, true/false for full_test
  startedAt   DateTime @default(now())
  completedAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts Attempt[]
}
